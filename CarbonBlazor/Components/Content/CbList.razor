@if (Ordered)
{
    <ol class="@ClassName" @attributes="AdditionalAttributes">@ChildContent</ol>
}
else
{
    <ul class="@ClassName" @attributes="AdditionalAttributes">@ChildContent</ul>
}

@code {
    [Parameter] public bool Ordered { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string ClassName => new CssBuilder("cb-list").Add("cb-list--ordered", Ordered).Add(Class).ToString();
}
