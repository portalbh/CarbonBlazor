@implements IAsyncDisposable
@inject IJSRuntime Js

@if (Open)
{
    <div class="cb-modal-layer" @onkeydown="OnKeyDown">
        <button class="cb-modal__overlay" type="button" aria-label="Close modal" @onclick="RequestClose"></button>
        <section id="@DialogId" class="@ClassName" role="dialog" aria-modal="true" aria-labelledby="@TitleId" aria-describedby="@DescriptionId" tabindex="-1" @attributes="AdditionalAttributes">
            <header class="cb-modal__header">
                @if (!string.IsNullOrWhiteSpace(Label))
                {
                    <div class="cb-modal__label">@Label</div>
                }
                <h2 id="@TitleId">@Title</h2>
                <button class="cb-modal__close" type="button" aria-label="Close modal" @onclick="RequestClose">×</button>
            </header>
            <div id="@DescriptionId" class="cb-modal__body">@ChildContent</div>
            @if (Footer is not null)
            {
                <footer class="cb-modal__footer">@Footer</footer>
            }
        </section>
    </div>
}

@code {
    private readonly string _id = $"cb-modal-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;

    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = "Modal";
    [Parameter] public string? Label { get; set; }
    [Parameter] public CbModalSize Size { get; set; } = CbModalSize.Medium;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string DialogId => _id;
    private string TitleId => $"{_id}-title";
    private string DescriptionId => $"{_id}-description";
    private string ClassName => new CssBuilder("cb-modal").Add($"cb-modal--{Size.ToString().ToLowerInvariant()}").Add(Class).ToString();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open)
        {
            _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./_content/CarbonBlazor/carbon-blazor.js");
            await _module.InvokeVoidAsync("setBodyScrollLock", true);
            await _module.InvokeVoidAsync("focusFirst", $"#{DialogId}");
        }
    }

    private async Task RequestClose()
    {
        Open = false;
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("setBodyScrollLock", false);
        }
        await OpenChanged.InvokeAsync(false);
    }

    private async Task OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            await RequestClose();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("setBodyScrollLock", false);
            await _module.DisposeAsync();
        }
    }
}
