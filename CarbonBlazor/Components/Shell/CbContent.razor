<main class="@ClassName" id="@Id" tabindex="-1" @attributes="AdditionalAttributes">
    @ChildContent
</main>

@code {
    [Parameter] public string Id { get; set; } = "main-content";
    [Parameter] public bool WithSideNav { get; set; } = true;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ClassName => new CssBuilder("cb-content").Add("cb-content--with-side-nav", WithSideNav).Add(Class).ToString();
}
