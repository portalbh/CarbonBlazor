<div class="@ClassName" role="group" aria-label="@Label" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string Label { get; set; } = "Actions";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string ClassName => new CssBuilder("cb-button-set").Add(Class).ToString();
}
