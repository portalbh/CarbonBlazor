<div class="@ClassName" @attributes="AdditionalAttributes">
    <CbIconButton Label="@Label" Icon="@Icon" OnClick="Toggle" aria-haspopup="menu" aria-expanded="@Open" />
    @if (Open)
    {
        <div class="cb-menu cb-menu--overflow" role="menu" @onkeydown="OnKeyDown">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "More actions";
    [Parameter] public string Icon { get; set; } = "⋯";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private bool Open { get; set; }
    private string ClassName => new CssBuilder("cb-overflow-menu").Add(Class).ToString();
    private void Toggle() => Open = !Open;
    private void OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            Open = false;
        }
    }
}
