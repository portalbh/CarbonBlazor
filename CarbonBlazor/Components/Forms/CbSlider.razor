<div class="cb-form-item cb-slider">
    <label class="cb-label" for="@InputId">@Label</label>
    <div class="cb-slider__row">
        <input id="@InputId" type="range" min="@Min" max="@Max" step="@Step" value="@Value" disabled="@Disabled" @oninput="OnInput" @attributes="AdditionalAttributes" />
        <output for="@InputId">@Value</output>
    </div>
</div>

@code {
    private readonly string _id = $"cb-slider-{Guid.NewGuid():N}";
    [Parameter] public string Label { get; set; } = "Slider";
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string InputId => Id ?? _id;
    private async Task OnInput(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), out var value))
        {
            Value = value;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}
