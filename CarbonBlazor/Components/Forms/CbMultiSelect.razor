<div class="cb-form-item">
    <label class="cb-label" for="@InputId">@Label</label>
    <select id="@InputId" class="cb-select cb-multiselect" multiple size="@Size" disabled="@Disabled" @onchange="OnChange" @attributes="AdditionalAttributes">
        @foreach (var item in Items)
        {
            <option value="@item" selected="@SelectedValues.Contains(item)">@item</option>
        }
        @ChildContent
    </select>
    @if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div class="cb-helper">@HelperText</div>
    }
</div>

@code {
    private readonly string _id = $"cb-multiselect-{Guid.NewGuid():N}";
    [Parameter] public string Label { get; set; } = "Multiselect";
    [Parameter] public IReadOnlyList<string> SelectedValues { get; set; } = [];
    [Parameter] public EventCallback<IReadOnlyList<string>> SelectedValuesChanged { get; set; }
    [Parameter] public IEnumerable<string> Items { get; set; } = [];
    [Parameter] public int Size { get; set; } = 4;
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string InputId => Id ?? _id;
    private async Task OnChange(ChangeEventArgs args)
    {
        if (args.Value is string[] values)
        {
            SelectedValues = values;
            await SelectedValuesChanged.InvokeAsync(SelectedValues);
        }
    }
}
