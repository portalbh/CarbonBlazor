<CbTextInput Label="@Label" Type="search" Value="@Value" ValueChanged="@ValueChanged" Placeholder="@Placeholder" HelperText="@HelperText" Disabled="@Disabled" ReadOnly="@ReadOnly" Class="cb-search" />

@code {
    [Parameter] public string Label { get; set; } = "Search";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; } = "Search";
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
}
