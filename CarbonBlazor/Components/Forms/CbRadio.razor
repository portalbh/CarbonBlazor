<label class="cb-radio">
    <input type="radio" name="@GroupName" value="@Value" checked="@Selected" disabled="@Disabled" @onchange="OnChange" @attributes="AdditionalAttributes" />
    <span class="cb-radio__dot" aria-hidden="true"></span>
    <span>@ChildContent</span>
</label>

@code {
    [CascadingParameter] internal CbRadioGroup? Group { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string GroupName => Group?.Name ?? Group?.GroupName ?? "cb-radio";
    private bool Selected => Group?.Value == Value;
    private async Task OnChange() => await (Group?.SetValue(Value) ?? Task.CompletedTask);
}
