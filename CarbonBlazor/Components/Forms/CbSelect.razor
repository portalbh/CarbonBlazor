<div class="cb-form-item">
    <label class="cb-label" for="@InputId">@Label</label>
    <select id="@InputId" class="cb-select" value="@Value" disabled="@Disabled" aria-invalid="@Invalid" @onchange="OnChange" @attributes="AdditionalAttributes">
        @ChildContent
    </select>
    @if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div class="cb-helper">@HelperText</div>
    }
</div>

@code {
    private readonly string _id = $"cb-select-{Guid.NewGuid():N}";
    [Parameter] public string Label { get; set; } = "Select";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string InputId => Id ?? _id;
    private async Task OnChange(ChangeEventArgs args)
    {
        Value = args.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
