<span class="@ClassName" role="status" aria-live="polite" @attributes="AdditionalAttributes">
    <span class="cb-spinner" aria-hidden="true"></span>
    <span>@Text</span>
</span>

@code {
    [Parameter] public string Text { get; set; } = "Loading";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    private string ClassName => new CssBuilder("cb-inline-loading").Add(Class).ToString();
}
