@page "/data"

<PageTitle>Data</PageTitle>

<h1>Data components</h1>
<p class="docs-lede">Data tables include sortable headers and optional row selection. Pagination keeps essential controls visible on small screens.</p>

<CbDataTable TItem="DemoRow" Title="Release tasks" Items="@Rows" Columns="@Columns" Selectable="true" />
<CbPagination TotalItems="42" @bind-Page="_page" @bind-PageSize="_pageSize" />

<section class="docs-section">
    <h2>Structured list</h2>
    <CbStructuredList>
        <CbStructuredListRow Header="true">
            <CbStructuredListCell>Token</CbStructuredListCell>
            <CbStructuredListCell>Role</CbStructuredListCell>
        </CbStructuredListRow>
        <CbStructuredListRow>
            <CbStructuredListCell>background</CbStructuredListCell>
            <CbStructuredListCell>Page surface</CbStructuredListCell>
        </CbStructuredListRow>
    </CbStructuredList>
</section>

<section class="docs-section">
    <h2>Tree view</h2>
    <CbTreeView Nodes="@Tree" />
</section>

@code {
    private int _page = 1;
    private int _pageSize = 10;

    private IReadOnlyList<DemoRow> Rows { get; } =
    [
        new("Scaffold", "Complete", "Project"),
        new("Tokens", "Complete", "Foundations"),
        new("Docs", "In progress", "Documentation")
    ];

    private IReadOnlyList<CbDataTableColumn<DemoRow>> Columns { get; } =
    [
        new() { Header = "Task", Text = row => row.Task, SortKey = row => row.Task },
        new() { Header = "Status", Text = row => row.Status, SortKey = row => row.Status },
        new() { Header = "Area", Text = row => row.Area }
    ];

    private IReadOnlyList<CbTreeNode> Tree { get; } =
    [
        new()
        {
            Label = "CarbonBlazor",
            Expanded = true,
            Children =
            [
                new() { Label = "Components" },
                new() { Label = "Themes" },
                new() { Label = "Documentation" }
            ]
        }
    ];

    private sealed record DemoRow(string Task, string Status, string Area);
}
